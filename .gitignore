# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# ============================================================================
# Environment / secrets
# ============================================================================
.env
.env.local
